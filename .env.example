# MailScope Environment Variables

# --- API Keys ---
OPENAI_API_KEY=
VIRUSTOTAL_API_KEY=
URLSCAN_API_KEY=

# --- Service Toggles ---
# Set to false to disable external services
ENABLE_VIRUSTOTAL=true
ENABLE_URLSCAN=true
ENABLE_LLM=true

# --- urlscan config ---
# Visibility for urlscan submissions: public, unlisted, or private
URLSCAN_VISIBILITY=private

# --- LLM config ---
LLM_MODEL=gpt-4o

# --- Polling ---
MAX_POLL_SECONDS=120
POLL_INTERVAL_SECONDS=5

# --- App ---
MAX_UPLOAD_SIZE_MB=25
