# MailScope Environment Variables

# --- API Keys ---
VIRUSTOTAL_API_KEY=
URLSCAN_API_KEY=

# --- Service Toggles ---
# Set to false to disable external services
ENABLE_VIRUSTOTAL=true
ENABLE_URLSCAN=true

# --- LLM (Legacy — disabled by default in Copilot-ready mode) ---
# Only enable if running in standalone mode without Copilot
ENABLE_LLM=false
OPENAI_API_KEY=
LLM_MODEL=gpt-4o

# --- Service Mode ---
# "standalone" = with web UI, "service" = headless API for Copilot
SERVICE_MODE=standalone

# --- urlscan config ---
# Visibility for urlscan submissions: public, unlisted, or private
URLSCAN_VISIBILITY=private

# --- Polling ---
MAX_POLL_SECONDS=120
POLL_INTERVAL_SECONDS=5

# --- App ---
MAX_UPLOAD_SIZE_MB=25

# --- Retention ---
# TTL for completed jobs in hours (0 = no auto-cleanup)
JOB_RETENTION_HOURS=0
